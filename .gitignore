__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ===================================
# Virtual Environments
# ===================================
kaya_chatbot_env/
venv/
env/
ENV/
.venv

# ===================================
# Data Files (large/sensitive)
# ===================================
data/facebook/
data/insta/
data/wpp/
data/rag_db/
*.jsonl
*.json
# Only sanitized TEMPLATES are tracked. The real data/group_members.json,
# data/group_knowledge.json and data/golden_test_conversations.json contain
# personal data about real people (health, relationships, locations) and MUST
# stay local / git-ignored. See AUDIT_REPORT.md P0-2.
!data/group_members.example.json
!data/group_knowledge.example.json
!data/golden_test_conversations.example.json
*.txt

# ChromaDB files
chroma.sqlite3
*.sqlite3

# Exceptions: Keep config and documentation
!config.yaml
!README.md
!requirements.txt

# ===================================
# AI assistant / editor local configs
# ===================================
.claude/
.cursorrules
.github/copilot-instructions.md

# ===================================
# Credentials & Secrets (CRITICAL)
# ===================================
credentials.txt
.env
.env.local
*.key
*.pem
*.pfx

