# Models (large files)
# ===================================
models/
*.safetensors
*.bin
*.pth
*.onnx
*.pt
checkpoint-*/

# Exception: model profile YAML files in configs/ are config, not model weights
!configs/
!configs/models/
!configs/models/*.yaml

