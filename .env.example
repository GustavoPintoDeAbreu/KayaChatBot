# Kaya Chatbot Web App Environment Variables

# Cloudflare Tunnel Token (get from https://dash.cloudflare.com/)
# CLOUDFLARE_TOKEN=your_cloudflare_tunnel_token_here

# Allowed emails for authentication (comma-separated)
# ALLOWED_EMAILS=friend1@example.com,friend2@example.com,your@email.com

# Secret key for JWT tokens (generate a random string)
# SECRET_KEY=your-very-secure-random-secret-key-here

# Ollama configuration (usually no need to change)
# OLLAMA_BASE_URL=http://ollama:11434