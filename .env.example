# Copy to .env and fill in. .env is git-ignored — never commit real secrets.
# In CI/CD these are written from GitHub environment secrets (see DEPLOYMENT.md).

# LLM provider keys (knowledge generation / benchmarking)
XAI_API_KEY=
AZURE_OPENAI_API_KEY_gpt_41_mini=
AZURE_OPENAI_API_KEY_gpt_53_chat=

# Web app login (Gradio auth layer). Required when serving beyond localhost.
KAYA_WEB_USER=
KAYA_WEB_PASS=

# Cloudflare Tunnel token (remotely-managed tunnel). From the Cloudflare
# Zero Trust dashboard → Networks → Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=

# WhatsApp bridge (WAHA). Only needed when whatsapp.enabled with a real number —
# the mock flow (KAYA_WHATSAPP_MOCK=1) needs none of these.
KAYA_WAHA_API_KEY=
KAYA_WHATSAPP_WEBHOOK_TOKEN=
